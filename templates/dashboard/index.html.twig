{% extends 'base.html.twig' %}

{% block title %}Dashboard — AarhusAI Overview{% endblock %}

{% block subhead %}
    <div class="subhead">
        <div class="subhead__left">
            <span class="health-cluster">
                {% for key, healthy in siteHealth %}
                    {% if healthy is null %}
                        {% set health_class = 'health--unknown' %}
                    {% elseif healthy %}
                        {% set health_class = 'health--ok' %}
                    {% else %}
                        {% set health_class = 'health--bad' %}
                    {% endif %}
                    <span class="health {{ health_class }}">
                        <span class="health__dot" aria-hidden="true"></span>
                        {{ key|capitalize }}
                    </span>
                {% endfor %}
            </span>
        </div>
        <div class="subhead__right">
            <form method="post" action="{{ path('dashboard_sync') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('sync') }}">
                <button type="submit" class="btn btn--accent">
                    {{ include('icons/sync.html.twig') }}
                    Sync now
                </button>
            </form>
        </div>
    </div>
{% endblock %}

{% block body %}
    <header class="section-head reveal reveal-3">
        <div>
            <h1 class="section-head__title">Models</h1>
        </div>
        <div class="section-head__count">
            <strong>{{ models|length }}</strong>
            {{ models|length == 1 ? 'entry' : 'entries' }}
        </div>
    </header>

    <nav class="tabs reveal reveal-3" aria-label="Site filter">
        <a href="{{ path('dashboard') }}" class="tab"{% if activeSite is null %} aria-current="true"{% endif %}>
            All sites
        </a>
        {% for key in siteKeys %}
            <a href="{{ path('dashboard', {site: key}) }}" class="tab"{% if activeSite == key %} aria-current="true"{% endif %}>
                {{ key|capitalize }}
            </a>
        {% endfor %}
    </nav>

    <section class="index reveal reveal-4" data-controller="sortable">
        <div class="index__bar">
            <span>{% if activeSite %}{{ activeSite|capitalize }}{% else %}All sites{% endif %}</span>
            <span data-sortable-target="status">Sorted by Name · A→Z</span>
        </div>
        <div class="index__scroll">
            <table class="ledger">
                <thead>
                    <tr>
                        <th data-sortable-target="header" data-action="click->sortable#sort" data-sort-label="Name" scope="col">
                            Name <span class="sort-arrow" data-sort-arrow>&#x2195;</span>
                        </th>
                        <th scope="col">Base model</th>
                        {% if activeSite is null %}
                            <th scope="col">Site</th>
                        {% endif %}
                        <th scope="col">Updated</th>
                    </tr>
                </thead>
                {% for model in models %}
                    <tbody data-controller="toggle-row" data-sortable-target="body">
                        <tr>
                            <td class="ledger__name">
                                {% if model.description %}
                                    <button type="button"
                                        data-action="toggle-row#toggle"
                                        data-toggle-row-target="trigger"
                                        aria-expanded="false"
                                        class="ledger__name-toggle">
                                        {{ model.name }}
                                    </button>
                                {% else %}
                                    {{ model.name }}
                                {% endif %}
                            </td>
                            <td class="ledger__base">{{ model.baseModelId ?? '—' }}</td>
                            {% if activeSite is null %}
                                <td><span class="ledger__site">{{ model.site }}</span></td>
                            {% endif %}
                            <td class="ledger__date">{{ model.updatedAt|date('Y-m-d · H:i') }}</td>
                        </tr>
                        {% if model.description %}
                            <tr data-toggle-row-target="content" class="ledger__detail" style="display: none">
                                <td colspan="{{ activeSite is null ? 4 : 3 }}">
                                    <span class="ledger__detail-eyebrow">Description</span>
                                    <div class="ledger__detail-body">{{ model.description }}</div>
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                {% else %}
                    <tbody>
                        <tr>
                            <td colspan="{{ activeSite is null ? 4 : 3 }}" class="ledger__empty">
                                Nothing on file yet — run <code>bin/console app:sync-openwebui</code> to populate the ledger.
                            </td>
                        </tr>
                    </tbody>
                {% endfor %}
            </table>
        </div>
    </section>
{% endblock %}
