{% extends 'base.html.twig' %}

{% block title %}Dashboard - AarhusAI Overview{% endblock %}

{% block header_right %}
    <div class="flex items-center gap-4">
        {% for key, healthy in siteHealth %}
            <span class="inline-flex items-center gap-1.5 text-sm">
                {% if healthy is null %}
                    <span class="h-2.5 w-2.5 rounded-full bg-gray-400"></span>
                    <span class="text-gray-500">{{ key|capitalize }}</span>
                {% elseif healthy %}
                    <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
                    <span class="text-green-700">{{ key|capitalize }}</span>
                {% else %}
                    <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
                    <span class="text-red-700">{{ key|capitalize }}</span>
                {% endif %}
            </span>
        {% endfor %}
        <form method="post" action="{{ path('dashboard_sync') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('sync') }}">
            <button type="submit"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md transition-colors cursor-pointer">
                {{ include('icons/sync.html.twig') }}
                Sync
            </button>
        </form>
    </div>
{% endblock %}

{% block body %}
    {# Site selector pills #}
    <div class="mb-4 flex gap-2">
        <a href="{{ path('dashboard') }}"
            class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors {{ activeSite is null ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' }}">
            All Sites
        </a>
        {% for key in siteKeys %}
            <a href="{{ path('dashboard', { site: key }) }}"
                class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors {{ activeSite == key ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' }}">
                {{ key|capitalize }}
            </a>
        {% endfor %}
    </div>

    <div class="bg-white rounded-lg shadow" data-controller="tabs">
        {# Tab navigation #}
        <div class="p-3 pb-0">
            <ul class="relative flex flex-wrap p-1.5 list-none rounded-lg bg-slate-100" role="list">
                <li class="flex-auto text-center">
                    <button type="button" role="tab"
                        class="flex items-center justify-center w-full px-4 py-2 text-sm font-medium rounded-md transition-all ease-in-out cursor-pointer bg-white shadow text-indigo-600 border-b-2 border-indigo-500"
                        data-tabs-target="btn" data-action="tabs#select" aria-selected="true">
                        {{ include('icons/models.html.twig') }}
                        Models ({{ models|length }})
                    </button>
                </li>
                <li class="flex-auto text-center">
                    <button type="button" role="tab"
                        class="flex items-center justify-center w-full px-4 py-2 text-sm font-medium rounded-md transition-all ease-in-out cursor-pointer text-slate-500 border-b-2 border-transparent"
                        data-tabs-target="btn" data-action="tabs#select" aria-selected="false">
                        {{ include('icons/users.html.twig') }}
                        Users ({{ users|length }})
                    </button>
                </li>
                <li class="flex-auto text-center">
                    <button type="button" role="tab"
                        class="flex items-center justify-center w-full px-4 py-2 text-sm font-medium rounded-md transition-all ease-in-out cursor-pointer text-slate-500 border-b-2 border-transparent"
                        data-tabs-target="btn" data-action="tabs#select">
                        {{ include('icons/groups.html.twig') }}
                        Groups ({{ groups|length }})
                    </button>
                </li>
            </ul>
        </div>

        {# Build lookup maps for resolving principal IDs to names #}
        {% set user_map = {} %}
        {% for user in users %}
            {% set user_map = user_map|merge({ (user.externalId): user.name }) %}
        {% endfor %}
        {% set group_map = {} %}
        {% for group in groups %}
            {% set group_map = group_map|merge({ (group.externalId): group.name }) %}
        {% endfor %}

        {# Models panel #}
        <div data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200" data-controller="sortable">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700 select-none"
                                data-sortable-target="header" data-action="click->sortable#sort">
                                Name <span data-sort-arrow class="text-gray-400">&#x2195;</span>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Owner</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Base Model</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Access Grants</th>
                            {% if activeSite is null %}
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Site</th>
                            {% endif %}
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
                        </tr>
                    </thead>
                    {% for model in models %}
                        <tbody class="bg-white divide-y divide-gray-200" data-controller="toggle-row" data-sortable-target="body">
                            <tr>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                    {{ model.name }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.owner ? model.owner.name : '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.baseModelId ?? '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    {% if model.accessGrants|length > 0 %}
                                        <button type="button" data-action="toggle-row#toggle"
                                            class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-900 hover:bg-indigo-50 rounded px-1.5 py-0.5 -mx-1.5 -my-0.5 cursor-pointer">
                                            {{ model.accessGrants|length }}
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                        </button>
                                    {% else %}
                                        <span class="text-gray-500">0</span>
                                    {% endif %}
                                </td>
                                {% if activeSite is null %}
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ model.site }}</span>
                                    </td>
                                {% endif %}
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.updatedAt|date('Y-m-d H:i') }}</td>
                            </tr>
                            {% if model.accessGrants|length > 0 %}
                                <tr data-toggle-row-target="content" style="display: none">
                                    <td colspan="{{ activeSite is null ? 6 : 5 }}" class="px-6 py-4 bg-gray-50">
                                        {# Group grants by principalType+principalId, groups first then users #}
                                        {% set grouped_groups = {} %}
                                        {% set grouped_users = {} %}
                                        {% for grant in model.accessGrants %}
                                            {% set key = grant.principalType ~ ':' ~ grant.principalId %}
                                            {% if grant.principalType == 'group' %}
                                                {% if grouped_groups[key] is defined %}
                                                    {% set grouped_groups = grouped_groups|merge({ (key): grouped_groups[key]|merge({ permissions: grouped_groups[key].permissions|merge([grant.permission]) }) }) %}
                                                {% else %}
                                                    {% set grouped_groups = grouped_groups|merge({ (key): { principalType: grant.principalType, principalId: grant.principalId, permissions: [grant.permission] } }) %}
                                                {% endif %}
                                            {% else %}
                                                {% if grouped_users[key] is defined %}
                                                    {% set grouped_users = grouped_users|merge({ (key): grouped_users[key]|merge({ permissions: grouped_users[key].permissions|merge([grant.permission]) }) }) %}
                                                {% else %}
                                                    {% set grouped_users = grouped_users|merge({ (key): { principalType: grant.principalType, principalId: grant.principalId, permissions: [grant.permission] } }) %}
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                        {% set grouped = grouped_groups|merge(grouped_users) %}
                                        <table class="min-w-full text-sm table-fixed">
                                            <colgroup>
                                                <col style="width: 15%">
                                                <col style="width: 55%">
                                                <col style="width: 30%">
                                            </colgroup>
                                            <thead>
                                                <tr class="text-xs text-gray-500 uppercase">
                                                    <th class="pb-2 pr-4 text-left font-medium">Type</th>
                                                    <th class="pb-2 pr-4 text-left font-medium">Name</th>
                                                    <th class="pb-2 text-left font-medium">Permissions</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-200">
                                                {% for entry in grouped %}
                                                    <tr>
                                                        <td class="py-1.5 pr-4">
                                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                                                {{ entry.principalType == 'group' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800' }}">
                                                                {{ entry.principalType }}
                                                            </span>
                                                        </td>
                                                        <td class="py-1.5 pr-4 text-gray-900">
                                                            {% if entry.principalType == 'group' %}
                                                                {{ group_map[entry.principalId] ?? entry.principalId }}
                                                            {% elseif entry.principalType == 'user' %}
                                                                {{ user_map[entry.principalId] ?? entry.principalId }}
                                                            {% else %}
                                                                {{ entry.principalId }}
                                                            {% endif %}
                                                        </td>
                                                        <td class="py-1.5">
                                                            {% for perm in entry.permissions|sort %}
                                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                                                    {{ perm == 'write' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' }}">
                                                                    {{ perm }}
                                                                </span>
                                                            {% endfor %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    {% else %}
                        <tbody class="bg-white">
                            <tr>
                                <td colspan="{{ activeSite is null ? 6 : 5 }}" class="px-6 py-4 text-sm text-gray-500 text-center">No models synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>

        {# Users panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200" data-controller="sortable">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700 select-none"
                                data-sortable-target="header" data-action="click->sortable#sort">
                                Name <span data-sort-arrow class="text-gray-400">&#x2195;</span>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Groups</th>
                            {% if activeSite is null %}
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Site</th>
                            {% endif %}
                        </tr>
                    </thead>
                    {% for user in users %}
                        <tbody class="bg-white divide-y divide-gray-200" data-controller="toggle-row" data-sortable-target="body">
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ user.name }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ user.email }}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {{ user.role == 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-800' }}">
                                        {{ user.role }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    {% if user.groups|length > 0 %}
                                        <button type="button" data-action="toggle-row#toggle"
                                            class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-900 hover:bg-indigo-50 rounded px-1.5 py-0.5 -mx-1.5 -my-0.5 cursor-pointer">
                                            {{ user.groups|length }}
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                        </button>
                                    {% else %}
                                        <span class="text-gray-500">0</span>
                                    {% endif %}
                                </td>
                                {% if activeSite is null %}
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ user.site }}</span>
                                    </td>
                                {% endif %}
                            </tr>
                            {% if user.groups|length > 0 %}
                                <tr data-toggle-row-target="content" style="display: none">
                                    <td colspan="{{ activeSite is null ? 5 : 4 }}" class="px-6 py-4 bg-gray-50">
                                        <div class="flex flex-wrap gap-1.5">
                                            {% for group in user.groups|sort((a, b) => a.name <=> b.name) %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">{{ group.name }}</span>
                                            {% endfor %}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    {% else %}
                        <tbody class="bg-white">
                            <tr>
                                <td colspan="{{ activeSite is null ? 5 : 4 }}" class="px-6 py-4 text-sm text-gray-500 text-center">No users synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>

        {# Groups panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200" data-controller="sortable">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700 select-none" style="width: {{ activeSite is null ? '25%' : '30%' }}"
                                data-sortable-target="header" data-action="click->sortable#sort">
                                Name <span data-sort-arrow class="text-gray-400">&#x2195;</span>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" style="width: {{ activeSite is null ? '55%' : '70%' }}">Members</th>
                            {% if activeSite is null %}
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider" style="width: 20%">Site</th>
                            {% endif %}
                        </tr>
                    </thead>
                    {% set preview_count = activeSite is null ? 3 : 5 %}
                    {% for group in groups %}
                        {% set sorted_users = group.users|sort((a, b) => a.name <=> b.name) %}
                        <tbody class="bg-white divide-y divide-gray-200" data-controller="toggle-row" data-sortable-target="body">
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ group.name }}</td>
                                <td class="px-6 py-4 text-sm">
                                    <div class="flex items-start gap-1.5 flex-nowrap">
                                        <div class="flex items-center gap-1.5 flex-wrap overflow-hidden flex-1" style="max-height: 1.625rem">
                                            {% for user in sorted_users|slice(0, preview_count) %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 shrink-0">{{ user.name }}</span>
                                            {% endfor %}
                                        </div>
                                        {% if sorted_users|length > preview_count %}
                                            <button type="button" data-action="toggle-row#toggle"
                                                class="inline-flex items-center gap-1 bg-indigo-100 text-indigo-700 hover:bg-indigo-200 rounded-full px-2 py-0.5 cursor-pointer text-xs font-medium shrink-0">
                                                <span data-toggle-row-target="label" data-swap="show less">+{{ sorted_users|length - preview_count }} more</span>
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                            </button>
                                        {% endif %}
                                    </div>
                                    {% if sorted_users|length > preview_count %}
                                        <div data-toggle-row-target="content" style="display: none" class="flex flex-wrap gap-1.5 mt-1.5">
                                            {% for user in sorted_users|slice(preview_count) %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">{{ user.name }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </td>
                                {% if activeSite is null %}
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ group.site }}</span>
                                    </td>
                                {% endif %}
                            </tr>
                        </tbody>
                    {% else %}
                        <tbody class="bg-white">
                            <tr>
                                <td colspan="{{ activeSite is null ? 3 : 2 }}" class="px-6 py-4 text-sm text-gray-500 text-center">No groups synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>
    </div>
{% endblock %}
