{% extends 'base.html.twig' %}

{% block title %}Dashboard - AarhusAI Overview{% endblock %}

{% block header_right %}
    <div class="flex items-center gap-4">
        {% for key, healthy in siteHealth %}
            <span class="inline-flex items-center gap-1.5 text-sm">
                {% if healthy is null %}
                    <span class="h-2.5 w-2.5 rounded-full bg-gray-400"></span>
                    <span class="text-gray-500">{{ key|capitalize }}</span>
                {% elseif healthy %}
                    <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
                    <span class="text-green-700">{{ key|capitalize }}</span>
                {% else %}
                    <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
                    <span class="text-red-700">{{ key|capitalize }}</span>
                {% endif %}
            </span>
        {% endfor %}
        <form method="post" action="{{ path('dashboard_sync') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('sync') }}">
            <button type="submit"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md transition-colors cursor-pointer">
                {{ include('icons/sync.html.twig') }}
                Sync
            </button>
        </form>
    </div>
{% endblock %}

{% block body %}
    {# Site selector pills #}
    <div class="mb-4 flex gap-2">
        <a href="{{ path('dashboard') }}"
            class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors {{ activeSite is null ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' }}">
            All Sites
        </a>
        {% for key in siteKeys %}
            <a href="{{ path('dashboard', {site: key}) }}"
                class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors {{ activeSite == key ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' }}">
                {{ key|capitalize }}
            </a>
        {% endfor %}
    </div>

    <div class="bg-white rounded-lg shadow">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" data-controller="sortable">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700 select-none"
                            data-sortable-target="header" data-action="click->sortable#sort">
                            Name <span data-sort-arrow class="text-gray-400">&#x2195;</span>
                        </th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Base Model</th>
                        {% if activeSite is null %}
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Site</th>
                        {% endif %}
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
                    </tr>
                </thead>
                {% for model in models %}
                    <tbody class="bg-white divide-y divide-gray-200" data-controller="toggle-row" data-sortable-target="body">
                        <tr>
                            <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                {% if model.description %}
                                    <button type="button" data-action="toggle-row#toggle"
                                        class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-900 cursor-pointer">
                                        {{ model.name }}
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                    </button>
                                {% else %}
                                    {{ model.name }}
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.baseModelId ?? '-' }}</td>
                            {% if activeSite is null %}
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ model.site }}</span>
                                </td>
                            {% endif %}
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.updatedAt|date('Y-m-d H:i') }}</td>
                        </tr>
                        {% if model.description %}
                            <tr data-toggle-row-target="content" style="display: none">
                                <td colspan="{{ activeSite is null ? 4 : 3 }}" class="px-6 py-4 bg-gray-50 text-sm text-gray-700">
                                    {{ model.description }}
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                {% else %}
                    <tbody class="bg-white">
                        <tr>
                            <td colspan="{{ activeSite is null ? 4 : 3 }}" class="px-6 py-4 text-sm text-gray-500 text-center">No models synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                        </tr>
                    </tbody>
                {% endfor %}
            </table>
        </div>
    </div>
{% endblock %}
