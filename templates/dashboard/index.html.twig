{% extends 'base.html.twig' %}

{% block title %}Dashboard - AarhusAI Overview{% endblock %}

{% block header_right %}
    <span class="inline-flex items-center gap-1.5 text-sm">
        {% if healthy %}
            <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
            <span class="text-green-700">OpenWebUI Connected</span>
        {% else %}
            <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
            <span class="text-red-700">OpenWebUI Unreachable</span>
        {% endif %}
    </span>
{% endblock %}

{% block body %}
    <div class="bg-white rounded-lg shadow" data-controller="tabs">
        {# Tab navigation #}
        <div class="border-b border-gray-200">
            <nav class="flex -mb-px">
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-indigo-500 text-indigo-600 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Models ({{ models|length }})
                </button>
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Users ({{ users|length }})
                </button>
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Groups ({{ groups|length }})
                </button>
            </nav>
        </div>

        {# Models panel #}
        <div data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Owner</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Base Model</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Access Grants</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for model in models %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    {{ model.name }}
                                    {% if model.description %}
                                        <p class="text-xs text-gray-400 font-normal">{{ model.description|length > 80 ? model.description|slice(0, 80) ~ '...' : model.description }}</p>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.owner ? model.owner.name : '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.baseModelId ?? '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.accessGrants|length }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.updatedAt|date('Y-m-d H:i') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No models synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Users panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Groups</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for user in users %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ user.name }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ user.email }}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {{ user.role == 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-800' }}">
                                        {{ user.role }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ user.groups|length }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No users synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Groups panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Members</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for group in groups %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ group.name }}</td>
                                <td class="px-6 py-4 text-sm text-gray-500">{{ group.description ?? '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ group.memberCount }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="px-6 py-4 text-sm text-gray-500 text-center">No groups synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
