{% extends 'base.html.twig' %}

{% block title %}Dashboard - AarhusAI Overview{% endblock %}

{% block header_right %}
    <span class="inline-flex items-center gap-1.5 text-sm">
        {% if healthy %}
            <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
            <span class="text-green-700">OpenWebUI Connected</span>
        {% else %}
            <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
            <span class="text-red-700">OpenWebUI Unreachable</span>
        {% endif %}
    </span>
{% endblock %}

{% block body %}
    <div class="bg-white rounded-lg shadow" data-controller="tabs">
        {# Tab navigation #}
        <div class="border-b border-gray-200">
            <nav class="flex -mb-px">
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-indigo-500 text-indigo-600 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Models ({{ models|length }})
                </button>
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Users ({{ users|length }})
                </button>
                <button type="button" class="px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300"
                    data-tabs-target="btn" data-action="tabs#select">
                    Groups ({{ groups|length }})
                </button>
            </nav>
        </div>

        {# Build lookup maps for resolving principal IDs to names #}
        {% set user_map = {} %}
        {% for user in users %}
            {% set user_map = user_map|merge({ (user.externalId): user.name }) %}
        {% endfor %}
        {% set group_map = {} %}
        {% for group in groups %}
            {% set group_map = group_map|merge({ (group.externalId): group.name }) %}
        {% endfor %}

        {# Models panel #}
        <div data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Owner</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Base Model</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Access Grants</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
                        </tr>
                    </thead>
                    {% for model in models %}
                        <tbody class="bg-white divide-y divide-gray-200" data-controller="toggle-row">
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    {{ model.name }}
                                    {% if model.description %}
                                        <p class="text-xs text-gray-400 font-normal">{{ model.description|length > 80 ? model.description|slice(0, 80) ~ '...' : model.description }}</p>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.owner ? model.owner.name : '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.baseModelId ?? '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    {% if model.accessGrants|length > 0 %}
                                        <button type="button" data-action="toggle-row#toggle"
                                            class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-900 hover:bg-indigo-50 rounded px-1.5 py-0.5 -mx-1.5 -my-0.5 cursor-pointer">
                                            {{ model.accessGrants|length }}
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                        </button>
                                    {% else %}
                                        <span class="text-gray-500">0</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.updatedAt|date('Y-m-d H:i') }}</td>
                            </tr>
                            {% if model.accessGrants|length > 0 %}
                                <tr data-toggle-row-target="content" style="display: none">
                                    <td colspan="5" class="px-6 py-4 bg-gray-50">
                                        {# Group grants by principalType+principalId, groups first then users #}
                                        {% set grouped_groups = {} %}
                                        {% set grouped_users = {} %}
                                        {% for grant in model.accessGrants %}
                                            {% set key = grant.principalType ~ ':' ~ grant.principalId %}
                                            {% if grant.principalType == 'group' %}
                                                {% if grouped_groups[key] is defined %}
                                                    {% set grouped_groups = grouped_groups|merge({ (key): grouped_groups[key]|merge({ permissions: grouped_groups[key].permissions|merge([grant.permission]) }) }) %}
                                                {% else %}
                                                    {% set grouped_groups = grouped_groups|merge({ (key): { principalType: grant.principalType, principalId: grant.principalId, permissions: [grant.permission] } }) %}
                                                {% endif %}
                                            {% else %}
                                                {% if grouped_users[key] is defined %}
                                                    {% set grouped_users = grouped_users|merge({ (key): grouped_users[key]|merge({ permissions: grouped_users[key].permissions|merge([grant.permission]) }) }) %}
                                                {% else %}
                                                    {% set grouped_users = grouped_users|merge({ (key): { principalType: grant.principalType, principalId: grant.principalId, permissions: [grant.permission] } }) %}
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                        {% set grouped = grouped_groups|merge(grouped_users) %}
                                        <table class="min-w-full text-sm table-fixed">
                                            <colgroup>
                                                <col style="width: 15%">
                                                <col style="width: 55%">
                                                <col style="width: 30%">
                                            </colgroup>
                                            <thead>
                                                <tr class="text-xs text-gray-500 uppercase">
                                                    <th class="pb-2 pr-4 text-left font-medium">Type</th>
                                                    <th class="pb-2 pr-4 text-left font-medium">Name</th>
                                                    <th class="pb-2 text-left font-medium">Permissions</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-200">
                                                {% for entry in grouped %}
                                                    <tr>
                                                        <td class="py-1.5 pr-4">
                                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                                                {{ entry.principalType == 'group' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800' }}">
                                                                {{ entry.principalType }}
                                                            </span>
                                                        </td>
                                                        <td class="py-1.5 pr-4 text-gray-900">
                                                            {% if entry.principalType == 'group' %}
                                                                {{ group_map[entry.principalId] ?? entry.principalId }}
                                                            {% elseif entry.principalType == 'user' %}
                                                                {{ user_map[entry.principalId] ?? entry.principalId }}
                                                            {% else %}
                                                                {{ entry.principalId }}
                                                            {% endif %}
                                                        </td>
                                                        <td class="py-1.5">
                                                            {% for perm in entry.permissions|sort %}
                                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                                                    {{ perm == 'write' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' }}">
                                                                    {{ perm }}
                                                                </span>
                                                            {% endfor %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    {% else %}
                        <tbody class="bg-white">
                            <tr>
                                <td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No models synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>

        {# Users panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Groups</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for user in users %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ user.name }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ user.email }}</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {{ user.role == 'admin' ? 'bg-purple-100 text-purple-800' : 'bg-gray-100 text-gray-800' }}">
                                        {{ user.role }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ user.groups|length }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No users synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Groups panel #}
        <div style="display: none" data-tabs-target="panel">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Members</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for group in groups %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{{ group.name }}</td>
                                <td class="px-6 py-4 text-sm text-gray-500">{{ group.description ?? '-' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ group.memberCount }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="px-6 py-4 text-sm text-gray-500 text-center">No groups synced yet. Run <code>bin/console app:sync-openwebui</code></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
