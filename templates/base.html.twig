<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}AarhusAI Overview{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-gray-50 min-h-screen">
        <header class="bg-white shadow-sm">
            <div class="max-w-7xl mx-auto px-4 py-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between">
                    <h1 class="text-xl font-semibold text-gray-900">AarhusAI Overview</h1>
                    {% block header_right %}{% endblock %}
                </div>
            </div>
        </header>

        <main class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 px-4 py-3 rounded-md text-sm flex items-center justify-between {{ type == 'success' ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800' }}" data-controller="dismiss">
                        {{ message }}
                        <button type="button" data-action="dismiss#dismiss" class="ml-4 shrink-0 cursor-pointer opacity-50 hover:opacity-100">
                            {{ include('icons/close.html.twig') }}
                        </button>
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    
<!-- Claude Code Browser Feedback Widget (dev only) -->
<script>
  (function() {
    var h = location.hostname;
    var isDevHost = h === 'aarhusai-overview.local.itkdev.dk';
    if (isDevHost) {
      var s = document.createElement('script');
      s.src = 'http://localhost:9877/widget.js';
      s.id = 'claude-feedback-widget-script';
      document.body.appendChild(s);
    }
  })();
</script>
</body>
</html>
