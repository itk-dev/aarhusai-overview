<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}AarhusAI Overview{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="masthead reveal reveal-1">
            <div class="shell">
                <div class="masthead__main">
                    <a href="{{ path('dashboard') }}" class="wordmark" aria-label="AarhusAI Overview">
                        AarhusAI Overview
                        <span class="wordmark__tag">Models &amp; endpoints</span>
                    </a>

                    <div class="session">
                        {% if app.user %}
                            <div class="session__user">{{ app.user.userIdentifier }}</div>
                            <form method="post" action="{{ path('app_logout') }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit" class="btn">Logout</button>
                            </form>
                        {% endif %}
                    </div>
                </div>

                {% block subhead %}{% endblock %}
            </div>
        </header>

        <main class="main reveal reveal-2">
            <div class="shell">
                {% set flashes = app.flashes %}
                {% if flashes|length %}
                    <div class="flash-stack">
                        {% for type, messages in flashes %}
                            {% for message in messages %}
                                {% set flash_class = 'flash--error' %}
                                {% set flash_label = 'Error' %}
                                {% if type == 'success' %}{% set flash_class = 'flash--success' %}{% set flash_label = 'OK' %}{% endif %}
                                {% if type == 'warning' %}{% set flash_class = 'flash--warning' %}{% set flash_label = 'Notice' %}{% endif %}
                                <div class="flash {{ flash_class }}" data-controller="dismiss" role="status">
                                    <span class="flash__label">{{ flash_label }}</span>
                                    <span class="flash__msg">{{ message }}</span>
                                    <button type="button" data-action="dismiss#dismiss" class="flash__close" aria-label="Dismiss">
                                        {{ include('icons/close.html.twig') }}
                                    </button>
                                </div>
                            {% endfor %}
                        {% endfor %}
                    </div>
                {% endif %}

                {% block body %}{% endblock %}
            </div>
        </main>
    </body>
</html>
